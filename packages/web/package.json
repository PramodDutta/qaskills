{
  "name": "@qaskills/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "start:test": "QASKILLS_DISABLE_AUTH=1 next start --hostname 127.0.0.1 --port 3100",
    "test:e2e": "node $(node -p \"require.resolve('@playwright/test/cli')\") test",
    "test:post-flow": "QASKILLS_DISABLE_AUTH=1 corepack pnpm --workspace-root build && corepack pnpm test:unit && corepack pnpm test:e2e",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:playwright-cli": "tsx src/db/seed-playwright-cli.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.9.0",
    "@neondatabase/serverless": "^0.10.0",
    "@qaskills/shared": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@react-email/components": "^0.0.25",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/redis": "^1.34.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^0.460.0",
    "next": "^15.5.12",
    "next-themes": "^0.4.0",
    "posthog-js": "^1.190.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^3.0.3",
    "react-markdown": "^10.1.0",
    "recharts": "^2.13.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "typesense": "^1.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
